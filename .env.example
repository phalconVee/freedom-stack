APP_NAME=FreedomStack
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (DB_URL or DATABASE_URL for Railway: postgresql://user:password@mainline.proxy.rlwy.net:23235/railway)
DB_CONNECTION=pgsql
# DB_URL=postgresql://user:password@host:port/database
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=freedomstack
# DB_USERNAME=
# DB_PASSWORD=

# file = no DB needed for session (good for local when DB is remote/slow). database = persisted in DB.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# OpenRouter (OpenAI-compatible API)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-v3.2

# Comma-separated origins for CORS. Default includes localhost:5173, 3000, 8000 (SPA and Laravel).
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:8000

VITE_APP_NAME="${APP_NAME}"
# When SPA and API are same host (e.g. you open http://127.0.0.1:8000), leave this unset to avoid CORS.
# Set when SPA is on another origin (e.g. Vite dev server on :5173): http://localhost:8000/api
# VITE_API_BASE_URL=http://localhost:8000/api